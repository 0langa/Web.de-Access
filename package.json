{
  "name": "webde-access",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Private local MCP server for full Web.de mailbox access.",
  "bin": {
    "webde-auth": "./scripts/webde-auth.mjs"
  },
  "scripts": {
    "start": "node ./mcp/server.mjs",
    "check": "node --check ./mcp/server.mjs",
    "test": "node --test tests/*.test.mjs",
    "auth": "node ./scripts/webde-auth.mjs",
    "auth:login": "node ./scripts/webde-auth.mjs login",
    "auth:import-env": "node ./scripts/webde-auth.mjs import-env",
    "auth:status": "node ./scripts/webde-auth.mjs status",
    "auth:cleanup-env": "node ./scripts/webde-auth.mjs cleanup-env",
    "security:scan": "node ./scripts/security-scan.mjs",
    "smoke": "node ./scripts/smoke-test.mjs",
    "e2e:email": "node ./scripts/e2e-email.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "html-to-text": "^10.0.0",
    "imapflow": "^1.0.193",
    "keytar": "^7.9.0",
    "mailparser": "^3.9.11",
    "nodemailer": "^9.0.1",
    "zod": "^4.1.5"
  }
}
